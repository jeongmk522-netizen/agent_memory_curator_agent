{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlas.cloud/schemas/memory-event.schema.json",
  "title": "Agentlas Memory Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "timestamp",
    "source_agent",
    "task_id",
    "memory_kind",
    "content",
    "suggested_scope",
    "sensitivity",
    "confidence",
    "evidence_refs",
    "ttl"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^memevt_[A-Za-z0-9_-]{8,}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "source_agent": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string"
    },
    "agent_repo": {
      "type": "string"
    },
    "team_id": {
      "type": "string"
    },
    "memory_kind": {
      "type": "string",
      "enum": [
        "fact",
        "decision",
        "preference",
        "risk",
        "procedure",
        "hypothesis",
        "evidence",
        "deprecation",
        "conflict"
      ]
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1200
    },
    "suggested_scope": {
      "type": "string",
      "enum": [
        "user_identity",
        "team_memory",
        "agent_repo",
        "agent_team",
        "project",
        "session",
        "discard"
      ]
    },
    "sensitivity": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "private",
        "confidential",
        "secret"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "request_context": {
      "type": "object",
      "description": "Curated request-context capsule for recall. Do not store the raw user prompt.",
      "additionalProperties": false,
      "properties": {
        "user_intent": {
          "type": "string",
          "maxLength": 240
        },
        "trigger_terms": {
          "type": "array",
          "maxItems": 12,
          "items": {
            "type": "string",
            "maxLength": 40
          }
        },
        "cwd_at_request": {
          "type": ["string", "null"],
          "maxLength": 500
        },
        "target_project": {
          "type": ["string", "null"],
          "maxLength": 120
        },
        "target_path": {
          "type": ["string", "null"],
          "maxLength": 500
        },
        "cross_context": {
          "type": "boolean"
        },
        "outcome": {
          "type": ["string", "null"],
          "maxLength": 240
        }
      }
    },
    "ttl": {
      "type": "string",
      "enum": [
        "durable",
        "until_milestone",
        "session",
        "discard"
      ]
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "conflicts_with": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "redaction_notes": {
      "type": "string"
    },
    "human_review_required": {
      "type": "boolean"
    }
  }
}
